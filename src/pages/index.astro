---
import Layout from '../layouts/Layout.astro';
import { currencyFormatter, siteConfig } from '../data/site';

const basePrice = siteConfig.coffeeProduct.weightOptions[0]?.price ?? 0;
const shippingFee = siteConfig.shippingFee;

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'CafeOrCoffeeShop',
    name: siteConfig.brand,
    image: '/brand/autentiko-logo.png',
    description: siteConfig.description,
    servesCuisine: ['Coffee', 'Breakfast', 'Sandwiches'],
    telephone: siteConfig.whatsappDisplay,
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Plaza Gavilanes, Local 14, Los Gavilanes',
      addressLocality: 'Tlajomulco de Zúñiga',
      addressRegion: 'Jalisco',
      postalCode: '45645',
      addressCountry: 'MX',
    },
    url: Astro.url.toString(),
    sameAs: [siteConfig.instagramUrl, siteConfig.mapsUrl],
    openingHoursSpecification: [
      {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
        opens: '07:00',
        closes: '19:00',
      },
      {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: 'Saturday',
        opens: '08:00',
        closes: '14:00',
      },
      {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: 'Sunday',
        opens: '09:00',
        closes: '13:00',
      },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: `${siteConfig.brand} ${siteConfig.coffeeProduct.name}`,
    description: siteConfig.coffeeProduct.description,
    brand: siteConfig.brand,
    offers: siteConfig.coffeeProduct.weightOptions.map((option) => ({
      '@type': 'Offer',
      availability: 'https://schema.org/InStock',
      priceCurrency: 'MXN',
      price: option.price,
      itemCondition: 'https://schema.org/NewCondition',
      url: `${Astro.url.toString()}#comprar`,
      name: `${siteConfig.coffeeProduct.name} ${option.label}`,
    })),
  },
];
---

<Layout
  title="Auténtiko Café | Menú, ubicación y café de Chiapas en línea"
  description={siteConfig.description}
  structuredData={structuredData}
>
  <header class="site-header">
    <div class="shell site-header__inner">
      <a class="brand-lockup" href="#inicio" aria-label="Ir al inicio de Auténtiko Café">
        <img src="/brand/autentiko-logo.svg" alt="" width="96" height="96" />
        <div>
          <strong>{siteConfig.brand}</strong>
          <span>Tlajomulco, Jalisco</span>
        </div>
      </a>

      <nav class="site-nav" aria-label="Navegación principal">
        <a class="nav-link" href="#menu">Menú</a>
        <a class="nav-link" href="#comprar">Café en línea</a>
        <a class="nav-link" href="#ubicacion">Ubicación</a>
        <a class="nav-link" href={siteConfig.instagramUrl} target="_blank" rel="noreferrer">
          Instagram
        </a>
      </nav>
    </div>
  </header>

  <main id="inicio">
    <section class="section hero">
      <div class="shell">
        <div class="hero-grid">
          <div class="hero-copy">
            <span class="eyebrow">Auténtiko desde Los Gavilanes</span>
            <h1 class="display">La pausa favorita del sur de Guadalajara, con café de Chiapas y una barra hecha con oficio.</h1>
            <p class="lede">
              Ven por desayuno, por una conversación larga o por tu bolsa para casa. Auténtiko reúne
              menú completo, hospitalidad cercana y café tostado con criterio para beber aquí o en tu
              cocina.
            </p>

            <div class="hero-badges">
              <span class="pill"><strong>Recoger en tienda</strong> sin costo</span>
              <span class="pill">
                <strong>Envío a todo México</strong> {currencyFormatter.format(siteConfig.shippingFee)}
              </span>
              <span class="pill"><strong>Plaza Gavilanes</strong> Local 14</span>
            </div>

            <div class="button-row">
              <a class="button button-primary" href="#comprar">Comprar café</a>
              <a class="button button-secondary" href="#menu">Explorar menú</a>
              <a class="button button-text" href={siteConfig.whatsappUrl} target="_blank" rel="noreferrer">
                Pedir por WhatsApp
              </a>
            </div>

          </div>

          <aside class="hero-panel" aria-label="Resumen del concepto">
            <div class="hero-panel__top">
              <div class="hero-panel__intro">
                <strong>{siteConfig.shortBrand}</strong>
                <p>{siteConfig.tagline}</p>
              </div>

              <img src="/brand/autentiko-logo.svg" alt="" width="360" height="360" />
            </div>

            <div class="hero-stats">
              <div class="hero-stat">
                <strong>Café de Chiapas</strong>
                <span>Tostado con perfil pensado para casa, barra y regalo.</span>
              </div>
              <div class="hero-stat">
                <strong>Barra + cocina</strong>
                <span>Bebidas calientes, frías, frappés, baguettes y desayuno.</span>
              </div>
              <div class="hero-stat">
                <strong>Sur de Guadalajara</strong>
                <span>Plaza Gavilanes, local 14, Los Gavilanes.</span>
              </div>
            </div>

            <p class="hero-panel__note">
              Un lugar para volver entre semana, llevar a alguien el sábado y seguir tomando el mismo
              café en casa.
            </p>
          </aside>
        </div>
      </div>
    </section>

    <section class="section" id="historia">
      <div class="shell story-grid">
        <article class="story-card story-card--accent">
          <span class="eyebrow">Origen</span>
          <h2 class="section-title">Una barra cercana, con oficio de verdad.</h2>
          <p class="lede">
            {siteConfig.brand} nace con el espíritu de una casa de café honesta: producto bien hecho,
            sabores reconocibles y una atención que se siente cercana desde la primera taza.
          </p>

          <ul class="story-list">
            <li>Grano chiapaneco tostado por maestro tostador para una taza limpia y memorable.</li>
            <li>Recetas pensadas para el gusto diario: espresso, lattes, frappés y cocina de la casa.</li>
            <li>Un punto de encuentro al sur de Guadalajara, con café para llevar o recibir en casa.</li>
          </ul>
        </article>

        <article class="story-card">
          <span class="eyebrow">La visita</span>
          <h2 class="section-title">Aquí se viene por una pausa bien servida.</h2>
          <p class="lede">
            Auténtiko está pensado para esas horas que merecen algo mejor: una taza bien hecha, un
            desayuno que cae en su punto y una mesa donde la mañana se alarga sin prisa.
          </p>

          <ul class="story-list">
            <li>Bebidas calientes, frías y frappés preparadas para volver una y otra vez.</li>
            <li>Baguettes de masa madre natural y desayuno de la casa para acompañar la barra.</li>
            <li>Café de Chiapas disponible también para llevar a tu cocina, en grano o molido.</li>
          </ul>
        </article>
      </div>
    </section>

    <section class="section section--menu" id="menu">
      <div class="shell">
        <span class="eyebrow">Menú completo</span>
        <h2 class="section-title">Barra, cocina y antojos con sello de la casa.</h2>
        <p class="lede">
          Desde espressos limpios hasta baguettes de masa madre y desayuno de la casa. Todo el menú
          vigente de Auténtiko Café está aquí para revisar con calma antes de venir o escribirnos.
        </p>

        <div class="menu-grid">
          {siteConfig.menuSections.map((section) => (
            <article class="menu-card" id={section.id}>
              <span class="eyebrow">{section.eyebrow}</span>
              <h3>{section.title}</h3>
              <p>{section.note}</p>

              <ul class={section.id === 'baguettes' || section.id === 'desayunos' ? 'menu-food-list' : 'menu-list'}>
                {section.items.map((item) => (
                  <li>
                    <div class="menu-item">
                      <strong>{item.name}</strong>
                      <span>{item.price}</span>
                    </div>
                    {item.description && <p class="menu-item-desc">{item.description}</p>}
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>

        <p class="menu-note">
          Pan de masa madre natural, chipotle de la casa y café servido durante toda la jornada. Si
          quieres confirmar extras, disponibilidad o hacer un pedido especial, escríbenos por WhatsApp.
        </p>
      </div>
    </section>

    <section class="section section--purchase" id="comprar">
      <div class="shell purchase-grid">
        <article class="purchase-shell">
          <div class="purchase-card purchase-card--highlight">
            <span class="eyebrow">Para tu casa</span>
            <h2 class="section-title">Lleva el café de la casa hasta tu cocina.</h2>
            <p class="lede">{siteConfig.coffeeProduct.description}</p>
          </div>

          <div class="purchase-card">
            <h3>{siteConfig.coffeeProduct.name}</h3>
            <p>{siteConfig.coffeeProduct.subtitle}</p>
            <ul class="benefit-list">
              {siteConfig.coffeeProduct.benefits.map((benefit) => <li>{benefit}</li>)}
            </ul>
          </div>

        </article>

        <article class="selection-card">
          <span class="eyebrow">Pedido</span>
          <h3>Arma tu pedido</h3>
          <p>
            Elige presentación, molienda y forma de entrega. El pago se hace en una pantalla segura y
            solo solicita dirección de envío cuando corresponde.
          </p>

          <form class="checkout-panel" method="POST" action="/api/checkout" data-coffee-form>
            <fieldset class="choice-group">
              <legend><strong>Peso</strong></legend>
              {siteConfig.coffeeProduct.weightOptions.map((option, index) => (
                <div class="choice-card">
                  <input
                    type="radio"
                    id={`weight-${option.value}`}
                    name="weight"
                    value={option.value}
                    checked={index === 0}
                    data-price={option.price}
                  />
                  <label for={`weight-${option.value}`}>
                    <strong>{option.label} · {currencyFormatter.format(option.price)}</strong>
                    <span>{option.detail}</span>
                  </label>
                </div>
              ))}
            </fieldset>

            <fieldset class="choice-group">
              <legend><strong>Molienda</strong></legend>
              {siteConfig.coffeeProduct.grindOptions.map((option, index) => (
                <div class="choice-card">
                  <input
                    type="radio"
                    id={`grind-${option.value}`}
                    name="grind"
                    value={option.value}
                    checked={index === 0}
                  />
                  <label for={`grind-${option.value}`}>
                    <strong>{option.label}</strong>
                    <span>{option.detail}</span>
                  </label>
                </div>
              ))}
            </fieldset>

            <fieldset class="choice-group">
              <legend><strong>Entrega</strong></legend>
              {siteConfig.coffeeProduct.fulfillmentOptions.map((option, index) => (
                <div class="choice-card">
                  <input
                    type="radio"
                    id={`fulfillment-${option.value}`}
                    name="fulfillment"
                    value={option.value}
                    checked={index === 0}
                    data-fee={option.fee}
                  />
                  <label for={`fulfillment-${option.value}`}>
                    <strong>
                      {option.label}
                      {option.fee > 0 && ` · ${currencyFormatter.format(option.fee)}`}
                    </strong>
                    <span>{option.detail}</span>
                  </label>
                </div>
              ))}
            </fieldset>

            <div class="summary-box" aria-live="polite">
              <div class="summary-line">
                <span>Producto</span>
                <strong data-summary-product>{currencyFormatter.format(basePrice)}</strong>
              </div>
              <div class="summary-line">
                <span>Entrega</span>
                <strong data-summary-delivery>{currencyFormatter.format(shippingFee)}</strong>
              </div>
              <div class="summary-line summary-total">
                <span>Total estimado</span>
                <strong data-summary-total>{currencyFormatter.format(basePrice + shippingFee)}</strong>
              </div>
            </div>

            <p class="checkout-note">
              Si eliges envío, capturas tu dirección al pagar. Si prefieres recogerlo en tienda, solo
              cubres el café y pasas por él cuando te quede bien.
            </p>

            <div class="button-row">
              <button class="button button-primary" type="submit">Ir al pago</button>
              <a class="button button-secondary" href={siteConfig.whatsappUrl} target="_blank" rel="noreferrer">
                Resolver dudas por WhatsApp
              </a>
            </div>
          </form>
        </article>
      </div>
    </section>

    <section class="section section--contact" id="ubicacion">
      <div class="shell contact-grid">
        <article class="contact-card">
          <span class="eyebrow">Ubicación</span>
          <h2 class="section-title">Encuéntranos en Plaza Gavilanes.</h2>
          <p class="lede">
            {siteConfig.address}. Es una parada cómoda para desayunar, hacer una pausa bien servida o
            recoger el café que ya apartaste en línea.
          </p>

          <div class="contact-stack">
            <div class="note-card">
              <strong>Horarios</strong>
              <div class="hours-list">
                {siteConfig.hours.map((entry) => (
                  <div class="hours-row">
                    <span>{entry.label}</span>
                    <strong>{entry.value}</strong>
                  </div>
                ))}
              </div>
            </div>

            <div class="note-card">
              <strong>Conecta con Auténtiko</strong>
              <p>
                <a href={siteConfig.instagramUrl} target="_blank" rel="noreferrer">Instagram</a>
                {' · '}
                <a href={siteConfig.whatsappUrl} target="_blank" rel="noreferrer">
                  WhatsApp {siteConfig.whatsappDisplay}
                </a>
              </p>
            </div>

            <div class="note-card">
              <strong>Recoger en tienda</strong>
              <p>
                Si compras en línea, también puedes pasar por tu café cuando te quede mejor dentro del
                horario de servicio.
              </p>
            </div>
          </div>

          <a class="map-link" href={siteConfig.mapsUrl} target="_blank" rel="noreferrer">
            Abrir ubicación en Google Maps
          </a>
        </article>

        <article class="contact-card">
          <iframe
            title="Mapa de Auténtiko Café"
            src={siteConfig.mapsEmbedUrl}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          />
        </article>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="shell site-footer__inner">
      <div>
        <p>{siteConfig.brand} · Barra diaria, cocina ligera y café de Chiapas tostado con oficio.</p>
        <nav class="site-footer__nav" aria-label="Enlaces legales">
          <a href="/aviso-de-privacidad">Aviso de privacidad</a>
          <a href="/terminos-de-compra">Términos de compra</a>
          <a href="/envios-cancelaciones-y-devoluciones">Envíos, cancelaciones y devoluciones</a>
        </nav>
      </div>
      <p>Tlajomulco, Jalisco · Envíos a todo México · Recoger en tienda disponible</p>
    </div>
  </footer>

  <script is:inline define:vars={{ basePrice, shippingFee }}>
    const form = document.querySelector('[data-coffee-form]');

    if (form instanceof HTMLFormElement) {
      const productTarget = form.querySelector('[data-summary-product]');
      const deliveryTarget = form.querySelector('[data-summary-delivery]');
      const totalTarget = form.querySelector('[data-summary-total]');
      const formatCurrency = new Intl.NumberFormat('es-MX', {
        style: 'currency',
        currency: 'MXN',
        maximumFractionDigits: 0,
      });

      const updateSummary = () => {
        const selectedWeight = form.querySelector('input[name="weight"]:checked');
        const selectedFulfillment = form.querySelector('input[name="fulfillment"]:checked');

        const productValue = Number(selectedWeight?.dataset.price ?? basePrice);
        const deliveryValue = Number(selectedFulfillment?.dataset.fee ?? shippingFee);

        if (productTarget) productTarget.textContent = formatCurrency.format(productValue);
        if (deliveryTarget) {
          deliveryTarget.textContent =
            deliveryValue === 0 ? 'Sin costo' : formatCurrency.format(deliveryValue);
        }
        if (totalTarget) {
          totalTarget.textContent = formatCurrency.format(productValue + deliveryValue);
        }
      };

      form.addEventListener('change', updateSummary);
      updateSummary();
    }
  </script>
</Layout>
