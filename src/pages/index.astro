---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { siteConfig } from '../data/site';
import chilaquilesImage from '../assets/products/chilaquiles.jpeg';
import bebidaHeroImage from '../assets/products/bebida-2.jpeg';
import flatWhiteImage from '../assets/products/flat-white.jpeg';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CafeOrCoffeeShop',
  '@id': `${Astro.url.origin}/#cafeteria`,
  name: siteConfig.brand,
  image: '/brand/autentiko-logo.png',
  description: siteConfig.description,
  servesCuisine: ['Coffee', 'Breakfast', 'Sandwiches'],
  telephone: siteConfig.whatsappDisplay,
  priceRange: '$$',
  hasMap: siteConfig.mapsUrl,
  areaServed: ['Guadalajara', 'Tlajomulco de Zúñiga', 'México'],
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 20.5694,
    longitude: -103.4408,
  },
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Plaza Gavilanes, Local 14, Los Gavilanes',
    addressLocality: 'Tlajomulco de Zúñiga',
    addressRegion: 'Jalisco',
    postalCode: '45645',
    addressCountry: 'MX',
  },
  url: Astro.url.toString(),
  sameAs: [siteConfig.instagramUrl, siteConfig.mapsUrl],
};
---

<Layout
  title="Auténtiko Café | Cafetería en el sur de Guadalajara"
  description="Auténtiko Café es una cafetería en Los Gavilanes, al sur de Guadalajara, con barra cuidada, desayunos de la casa y café de Chiapas para llevar o pedir en línea."
  structuredData={structuredData}
>
  <SiteHeader currentPath="/" />

  <main>
    <section class="section hero">
      <div class="shell hero-grid hero-grid--home">
        <div class="hero-copy">
          <span class="eyebrow">Cafetería en el sur de Guadalajara</span>
          <h1 class="display">Café bien servido, desayunos con antojo y una pausa que sí se antoja repetir.</h1>
          <p class="lede">
            En Los Gavilanes está Auténtiko: una barra cercana con café de Chiapas, cocina de la casa
            y ese ritmo tranquilo que dan ganas de alargar un poco más.
          </p>

          <div class="hero-badges">
            <span class="pill"><strong>Plaza Gavilanes</strong> Local 14</span>
            <span class="pill"><strong>Recoger en tienda</strong> sin costo</span>
            <span class="pill"><strong>Envío a todo México</strong> para el café en línea</span>
          </div>

          <div class="button-row">
            <a class="button button-primary" href="/menu">Ver menú</a>
            <a class="button button-secondary" href="/cafe-en-linea">Comprar café</a>
            <a class="button button-text" href={siteConfig.whatsappUrl} target="_blank" rel="noreferrer">
              Pedir por WhatsApp
            </a>
          </div>
        </div>

        <aside class="hero-panel" aria-label="Rutas principales del sitio">
          <div class="hero-panel__top">
            <div class="hero-panel__intro">
              <strong>{siteConfig.shortBrand}</strong>
              <p>{siteConfig.tagline}</p>
            </div>

            <div class="hero-panel__mark" aria-hidden="true">
              <img src="/brand/autentiko-logo.svg" alt="" width="360" height="360" />
            </div>
          </div>

          <div class="route-grid">
            <a class="route-card" href="/menu">
              <strong>Menú completo</strong>
              <span>Bebidas calientes, frías, frappés, baguettes y desayunos.</span>
            </a>
            <a class="route-card" href="/cafe-en-linea">
              <strong>Café en línea</strong>
              <span>Compra 500 g o 1 kg, en grano o molido, con envío o pickup.</span>
            </a>
            <a class="route-card" href="/ubicacion">
              <strong>Ubicación</strong>
              <span>Horarios, mapa, contacto y todo para caerle sin rodeos.</span>
            </a>
          </div>

          <p class="hero-panel__note">
            Un lugar para desayunar entre semana, invitar a alguien el sábado o seguir tomando el
            mismo café en casa.
          </p>
        </aside>
      </div>
    </section>

    <section class="section" id="historia">
      <div class="shell story-grid">
        <article class="story-card story-card--accent">
          <span class="eyebrow">La casa</span>
          <h2 class="section-title">Una barra cercana, con oficio de verdad.</h2>
          <p class="lede">
            {siteConfig.brand} nace con el gusto por servir bien: producto honesto, sabores que
            reconfortan y una atención que se siente cercana desde la primera taza.
          </p>

          <ul class="story-list">
            <li>Grano chiapaneco tostado por maestro tostador para una taza limpia y memorable.</li>
            <li>Recetas pensadas para volverse parte de la rutina: espresso, lattes, frappés y cocina de la casa.</li>
            <li>Un rincón al sur de Guadalajara para pasar por tu café, quedarte un rato o llevarlo a casa.</li>
          </ul>
        </article>

        <article class="story-card">
          <span class="eyebrow">Lo que pasa aquí</span>
          <h2 class="section-title">Entre la barra y la cocina, todo invita a volver.</h2>
          <p class="lede">
            Auténtiko está hecho para esas mañanas y tardes que merecen algo mejor: una taza bien
            hecha, un desayuno con antojo y una mesa donde la conversación se queda un poco más.
          </p>

          <div class="mini-links">
            <a class="mini-link" href="/menu">
              <strong>Ver el menú</strong>
              <span>Chilaquiles, huevos, baguettes y bebidas de la casa.</span>
            </a>
            <a class="mini-link" href="/ubicacion">
              <strong>Planear la visita</strong>
              <span>Horarios, mapa y contacto directo por WhatsApp.</span>
            </a>
            <a class="mini-link" href="/cafe-en-linea">
              <strong>Llevar el café a casa</strong>
              <span>Compra en línea con envío nacional o recogida en tienda.</span>
            </a>
          </div>
        </article>
      </div>
    </section>

    <section class="section section--showcase" aria-labelledby="de-la-cocina">
      <div class="shell showcase-grid">
        <article class="showcase-copy">
          <span class="eyebrow">De la casa</span>
          <h2 class="section-title" id="de-la-cocina">Lo que sale de la barra y la cocina ya se ve como sabe.</h2>
          <p class="lede">
            El menú ya no vive escondido en una sola página. Ahora hay espacio para ver mejor los
            desayunos, las bebidas y el café que puedes pedir para casa.
          </p>
          <div class="button-row">
            <a class="button button-primary" href="/menu">Explorar el menú</a>
            <a class="button button-secondary" href="/cafe-en-linea">Ir a café en línea</a>
          </div>
        </article>

        <div class="showcase-gallery">
          <figure class="showcase-card showcase-card--featured">
            <Image src={chilaquilesImage} alt="Chilaquiles servidos en Auténtiko Café" widths={[480, 720, 960]} sizes="(max-width: 60rem) 100vw, 42vw" />
            <figcaption class="showcase-card__body">
              <strong>Chilaquiles de la casa</strong>
              <span>Para llegar con hambre y quedarse con ganas de volver.</span>
            </figcaption>
          </figure>

          <figure class="showcase-card">
            <Image src={bebidaHeroImage} alt="Bebida servida en la barra de Auténtiko Café" widths={[480, 720]} sizes="(max-width: 60rem) 100vw, 21vw" />
            <figcaption class="showcase-card__body">
              <strong>Barra fresca</strong>
              <span>Bebidas que saben a pausa bien servida.</span>
            </figcaption>
          </figure>

          <figure class="showcase-card">
            <Image src={flatWhiteImage} alt="Flat white servido en Auténtiko Café" widths={[480, 720]} sizes="(max-width: 60rem) 100vw, 21vw" />
            <figcaption class="showcase-card__body">
              <strong>Café diario</strong>
              <span>Tazas cuidadas para volver una y otra vez.</span>
            </figcaption>
          </figure>
        </div>
      </div>
    </section>

    <section class="section section--contact">
      <div class="shell visit-strip">
        <div>
          <span class="eyebrow">Visítanos</span>
          <h2 class="section-title">Todo lo importante para caerle a Auténtiko, sin buscar de más.</h2>
        </div>

        <div class="visit-strip__actions">
          <a class="button button-primary" href="/ubicacion">Ver ubicación y horarios</a>
          <a class="button button-secondary" href={siteConfig.mapsUrl} target="_blank" rel="noreferrer">
            Abrir en Maps
          </a>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</Layout>
