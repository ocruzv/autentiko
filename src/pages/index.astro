---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { siteConfig } from '../data/site';
import heroTable from '../assets/editorial/autentiko-table.png';
import chilaquilesImage from '../assets/products/chilaquiles.jpeg';
import burritosImage from '../assets/products/burritos-chicharron.jpeg';
import toastImage from '../assets/products/toast-desayuno.jpeg';
import flatWhiteImage from '../assets/products/flat-white.jpeg';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CafeOrCoffeeShop',
  '@id': `${Astro.url.origin}/#cafeteria`,
  name: siteConfig.brand,
  image: '/og-autentiko-cafe.svg',
  description: siteConfig.description,
  servesCuisine: ['Coffee', 'Breakfast', 'Sandwiches'],
  telephone: siteConfig.whatsappDisplay,
  priceRange: '$$',
  hasMap: siteConfig.mapsUrl,
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Plaza Gavilanes, Local 16, Los Gavilanes',
    addressLocality: 'Tlajomulco de Zúñiga',
    addressRegion: 'Jalisco',
    postalCode: '45645',
    addressCountry: 'MX',
  },
  url: Astro.url.toString(),
  sameAs: [siteConfig.instagramUrl, siteConfig.mapsUrl],
};
---

<Layout
  title="Auténtiko Café | Café y desayuno en Plaza Gavilanes"
  description="Café bien servido, desayunos generosos y sobremesa en Plaza Gavilanes, al sur de Guadalajara. Consulta el nuevo menú de Auténtiko Café."
  structuredData={structuredData}
>
  <SiteHeader currentPath="/" />

  <main>
    <section class="ac-hero" aria-labelledby="hero-title">
      <div class="ac-hero__media" aria-hidden="true" data-hero-media>
        <Image
          src={heroTable}
          alt=""
          widths={[720, 1080, 1440, 1920]}
          sizes="100vw"
          loading="eager"
          fetchpriority="high"
        />
      </div>
      <div class="ac-hero__wash"></div>

      <div class="ac-shell ac-hero__content">
        <div class="ac-hero__copy">
          <span class="ac-kicker ac-kicker--light">Plaza Gavilanes · Local 16</span>
          <h1 id="hero-title">Aquí se viene<br />a comer <em>bien.</em></h1>
          <p>
            Café bien servido, desayunos con carácter y una mesa donde la mañana puede tomarse su tiempo.
          </p>
          <div class="ac-actions">
            <a class="ac-button ac-button--cream" href="/menu">Descubrir el menú <span aria-hidden="true">↗</span></a>
            <a class="ac-link ac-link--light" href="/ubicacion">Ver horarios y ubicación</a>
          </div>
        </div>

        <div class="ac-hero__stamp" aria-hidden="true">
          <img src="/brand/coffee-sun.svg" alt="" width="220" height="220" />
          <span>CAFÉ · COCINA · SOBREMESA</span>
        </div>

        <span class="ac-scroll-cue" aria-hidden="true">Desliza para entrar <i></i></span>
      </div>
    </section>

    <div class="ac-marquee" aria-label="Especialidades de Auténtiko Café">
      <div>
        <span>CAFÉ DE CHIAPAS</span><i>✦</i><span>CHILAQUILES ROJOS</span><i>✦</i><span>FLAT WHITE</span><i>✦</i><span>PAN DE MASA MADRE</span><i>✦</i><span>DESAYUNO TODO EL DÍA</span><i>✦</i>
        <span aria-hidden="true">CAFÉ DE CHIAPAS</span><i aria-hidden="true">✦</i><span aria-hidden="true">CHILAQUILES ROJOS</span><i aria-hidden="true">✦</i><span aria-hidden="true">FLAT WHITE</span><i aria-hidden="true">✦</i><span aria-hidden="true">PAN DE MASA MADRE</span><i aria-hidden="true">✦</i><span aria-hidden="true">DESAYUNO TODO EL DÍA</span><i aria-hidden="true">✦</i>
      </div>
    </div>

    <section class="ac-intro ac-section">
      <div class="ac-shell ac-intro__grid">
        <p class="ac-intro__index" data-reveal>01 / LA CASA</p>
        <div data-reveal>
          <span class="ac-kicker">El sur también desayuna bonito</span>
          <h2>No somos una pausa rápida. Somos la razón para hacerla.</h2>
        </div>
        <p class="ac-intro__body" data-reveal>
          Auténtiko es una barra de barrio con apetito de gran café: recetas francas, producto cuidado y gente que te recibe por tu nombre. Ven por un espresso; quédate por los chilaquiles.
        </p>
      </div>
    </section>

    <section class="ac-table ac-section" aria-labelledby="table-title">
      <div class="ac-shell ac-table__layout">
        <div class="ac-table__rail" data-reveal>
          <span class="ac-kicker">De la barra a la mesa</span>
          <h2 id="table-title">Cada antojo tiene su momento.</h2>
          <p>Desayunos de mañana larga, café de paso y algo frío cuando pega el sol.</p>
          <a class="ac-link" href="/menu">Ver todos los precios <span aria-hidden="true">↗</span></a>
        </div>

        <div class="ac-food-gallery">
          <figure class="ac-food ac-food--large" data-reveal>
            <Image src={chilaquilesImage} alt="Chilaquiles rojos de Auténtiko Café" widths={[640, 960, 1280]} sizes="(max-width: 52rem) 100vw, 54vw" />
            <figcaption><span>01</span><strong>Chilaquiles rojos</strong><small>Crujientes, cremosos, de los que sí despiertan.</small></figcaption>
          </figure>
          <figure class="ac-food ac-food--portrait" data-reveal>
            <Image src={flatWhiteImage} alt="Flat white servido en una taza de Auténtiko Café" widths={[480, 720]} sizes="(max-width: 52rem) 92vw, 30vw" />
            <figcaption><span>02</span><strong>Flat white</strong><small>Una taza precisa, sin hacer tanto ruido.</small></figcaption>
          </figure>
          <figure class="ac-food ac-food--wide" data-reveal>
            <Image src={burritosImage} alt="Burritos de chicharrón servidos en Auténtiko Café" widths={[640, 960]} sizes="(max-width: 52rem) 100vw, 44vw" />
            <figcaption><span>03</span><strong>Burritos de chicharrón</strong><small>Doraditos, servidos con aguacate.</small></figcaption>
          </figure>
          <figure class="ac-food ac-food--small" data-reveal>
            <Image src={toastImage} alt="Toast de desayuno con ensalada servido en Auténtiko Café" widths={[480, 720]} sizes="(max-width: 52rem) 80vw, 26vw" />
            <figcaption><span>04</span><strong>Toast de desayuno</strong><small>Para llegar con hambre.</small></figcaption>
          </figure>
        </div>
      </div>
    </section>

    <section class="ac-menu-preview ac-section" aria-labelledby="menu-preview-title">
      <div class="ac-shell">
        <div class="ac-menu-preview__head" data-reveal>
          <div>
            <span class="ac-kicker ac-kicker--light">Una probadita</span>
            <h2 id="menu-preview-title">El menú cambió.<br />El antojo también.</h2>
          </div>
          <p>Precios claros, porciones honestas y suficientes razones para volver otro día.</p>
        </div>

        <div class="ac-menu-lines">
          <a href="/menu#calientes" data-reveal><span>01</span><strong>Espresso &amp; leche</strong><small>Desde $25</small><i>↗</i></a>
          <a href="/menu#rancho" data-reveal><span>02</span><strong>Desayunos de rancho</strong><small>Desde $129</small><i>↗</i></a>
          <a href="/menu#baguettes" data-reveal><span>03</span><strong>Baguettes de masa madre</strong><small>Desde $119</small><i>↗</i></a>
          <a href="/menu#frappes" data-reveal><span>04</span><strong>Fríos &amp; frappés</strong><small>Desde $75</small><i>↗</i></a>
        </div>

        <a class="ac-button ac-button--tomato" href="/menu">Abrir el menú completo <span aria-hidden="true">↗</span></a>
      </div>
    </section>

    <section class="ac-welcome ac-section" aria-labelledby="welcome-title">
      <div class="ac-shell ac-welcome__grid">
        <div class="ac-welcome__art" data-reveal>
          <span class="ac-welcome__sun"></span>
          <img src="/brand/nacho-host.svg" alt="Ilustración de Nacho con mandil y una tablet, listo para tomar la orden" width="920" height="1040" loading="lazy" />
        </div>
        <div class="ac-welcome__copy" data-reveal>
          <span class="ac-kicker">El anfitrión</span>
          <h2 id="welcome-title">“Bienvenidos a Auténtiko Café.”</h2>
          <p>
            Nacho y el equipo están listos para encontrarte mesa, recomendarte algo rico y tomarte la orden. Lo demás se resuelve con café.
          </p>
          <a class="ac-link" href={siteConfig.whatsappUrl} target="_blank" rel="noreferrer">Escribir por WhatsApp <span aria-hidden="true">↗</span></a>
        </div>
      </div>
    </section>

    <section class="ac-visit" aria-labelledby="visit-title">
      <div class="ac-shell ac-visit__grid">
        <div data-reveal>
          <span class="ac-kicker ac-kicker--light">La mesa está puesta</span>
          <h2 id="visit-title">Nos vemos en<br />Plaza Gavilanes.</h2>
        </div>
        <div class="ac-visit__details" data-reveal>
          <p>{siteConfig.address}</p>
          {siteConfig.hours.map((entry) => <p><span>{entry.label}</span><strong>{entry.value}</strong></p>)}
          <div class="ac-actions">
            <a class="ac-button ac-button--cream" href={siteConfig.mapsUrl} target="_blank" rel="noreferrer">Cómo llegar <span aria-hidden="true">↗</span></a>
            <a class="ac-link ac-link--light" href="/ubicacion">Ver el mapa</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</Layout>

<script>
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const revealItems = document.querySelectorAll<HTMLElement>('[data-reveal]');

  if (reducedMotion) {
    revealItems.forEach((item) => item.classList.add('is-visible'));
  } else {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { rootMargin: '0px 0px -12% 0px', threshold: 0.12 },
    );
    revealItems.forEach((item) => observer.observe(item));

    const heroMedia = document.querySelector<HTMLElement>('[data-hero-media]');
    let ticking = false;
    const updateScroll = () => {
      document.documentElement.style.setProperty('--ac-scroll', String(window.scrollY));
      heroMedia?.style.setProperty('--hero-shift', `${Math.min(window.scrollY * 0.09, 80)}px`);
      document.querySelector('[data-header]')?.classList.toggle('is-scrolled', window.scrollY > 32);
      ticking = false;
    };
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(updateScroll);
        ticking = true;
      }
    }, { passive: true });
    updateScroll();
  }
</script>
