---
import { siteConfig } from '../data/site';
---

<footer class="ac-footer">
  <div class="ac-shell ac-footer__grid">
    <div class="ac-footer__brand">
      <img src="/brand/autentiko-logo.svg" alt="" width="88" height="88" />
      <p>Auténtiko Café</p>
      <span>Café, desayuno y sobremesa.</span>
    </div>

    <div class="ac-footer__block">
      <span class="ac-kicker">Dónde</span>
      <p>{siteConfig.address}</p>
      <a href={siteConfig.mapsUrl} target="_blank" rel="noreferrer">Abrir en Maps ↗</a>
    </div>

    <div class="ac-footer__block">
      <span class="ac-kicker">Cuándo</span>
      {siteConfig.hours.map((entry) => <p>{entry.label}<br /><strong>{entry.value}</strong></p>)}
    </div>

    <div class="ac-footer__block">
      <span class="ac-kicker">Hablemos</span>
      <a href={siteConfig.instagramUrl} target="_blank" rel="noreferrer">Instagram ↗</a>
      <a href={siteConfig.whatsappUrl} target="_blank" rel="noreferrer">WhatsApp ↗</a>
      <a href="/aviso-de-privacidad">Privacidad</a>
    </div>
  </div>

  <div class="ac-shell ac-footer__bottom">
    <span>© {new Date().getFullYear()} Auténtiko Café</span>
    <span>Los Gavilanes · Tlajomulco, Jalisco</span>
  </div>
</footer>
